    <script>

      keyphrasesSubmitEl.addEventListener("input", function() {
        multiWordTagReminderEl.style.display = "";
      });

      let keyphraseSuggestionsDebounceTimeout;
      
      let numEmojiSuggestionsClicked = 0;
      function emojiSuggestionClickHandler() {
        // If this is their first time clicking an emoji from the suggestions area, and they've typed ONLY *letters* into
        // the emoji combo box, then we assume they meant to type into the keyword box so we move the letters to the keyword
        // box.
        if(numEmojiSuggestionsClicked === 0 && /^[a-z\s]{3,30}$/.test(emojiSubmitEl.value)) {
          keyphrasesSubmitEl.value += keyphrasesSubmitEl.value.trim().endsWith(",") || !keyphrasesSubmitEl.value.trim() ? emojiSubmitEl.value.trim() : ", "+emojiSubmitEl.value.trim();
          emojiSubmitEl.value = "";
        }

        emojiSubmitEl.value += this.textContent;
        numEmojiSuggestionsClicked++;
      }
      function keywordSuggestionClickHandler() {
        let alreadyGotKeywords = new Set(keyphrasesSubmitEl.value.split(",").map(k => k.trim().toLowerCase()))
        if(alreadyGotKeywords.has(this.textContent)) {
          alreadyGotKeywords.delete(this.textContent);
          keyphrasesSubmitEl.value = [...alreadyGotKeywords].join(", ");
          this.style.background = "";
        } else {
          keyphrasesSubmitEl.value += keyphrasesSubmitEl.value.trim().endsWith(",") || !keyphrasesSubmitEl.value.trim() ? this.textContent : ", "+this.textContent;
          let isDarkMode = window.matchMedia('(prefers-color-scheme: dark)').matches;
          this.style.background = isDarkMode ? "#0583b5" : "#b4eaff";
        }
        clearTimeout(keyphraseSuggestionsDebounceTimeout);
        let opts = {updateEmojis:true, keywordsInput:getKeywordsForSuggestionsSearch()};
        if(searchCache[JSON.stringify(opts)]) { // if it's already in cache, execute instantly
          updateSuggestions(opts);
        } else {
          keyphraseSuggestionsDebounceTimeout = setTimeout(() => { updateSuggestions(opts) }, 400);
        }
      }

      emojiQuickSearchEl.addEventListener("input", function() {
        clearTimeout(keyphraseSuggestionsDebounceTimeout);
        let opts = {updateEmojis:true, keywordsInput:emojiQuickSearchEl.value, isQuickSearch:true};
        if(searchCache[JSON.stringify(opts)]) { // if it's already in cache, execute instantly
          updateSuggestions(opts);
        } else {
          keyphraseSuggestionsDebounceTimeout = setTimeout(() => { updateSuggestions(opts) }, 400);
        }
      });

      keywordsQuickSearchEl.addEventListener("input", function() {
        clearTimeout(keyphraseSuggestionsDebounceTimeout);
        let opts = {updateKeywords:true, keywordsInput:keywordsQuickSearchEl.value, isQuickSearch:true};
        if(searchCache[JSON.stringify(opts)]) { // if it's already in cache, execute instantly
          updateSuggestions(opts);
        } else {
          keyphraseSuggestionsDebounceTimeout = setTimeout(() => { updateSuggestions(opts) }, 400);
        }
      });

      keyphrasesSubmitEl.addEventListener("input", function() {
        // show/hide suggestion box:
        if(keyphrasesSubmitEl.value.replace(/,/g, "").trim()) {
          submissionSuggestionsWrapper.style.display = "";
          // keywordSuggestionsCtn.innerHTML = `<span style=" margin: 0.25rem; padding: 0.25rem; ">Loading...</span>`;
          // emojiSuggestionsCtn.innerHTML = `<span style=" margin: 0.25rem; padding: 0.25rem; ">Loading...</span>`;
          keywordSuggestionsCtn.style.opacity = 0.6;
          emojiSuggestionsCtn.style.opacity = 0.6;
        } else {
          // submissionSuggestionsWrapper.style.display = "none";
        }
        // load emoji and keyword suggestions:
        clearTimeout(keyphraseSuggestionsDebounceTimeout);
        let opts = {updateKeywords:true, updateEmojis:true, keywordsInput:getKeywordsForSuggestionsSearch()};
        if(searchCache[JSON.stringify(opts)]) { // if it's already in cache, execute instantly
          updateSuggestions(opts);
        } else {
          keyphraseSuggestionsDebounceTimeout = setTimeout(() => { updateSuggestions(opts) }, 400);
        }
      });

      // The current UX isn't ideal - some people think they need to type keywords into the emojiSubmitEl input.
      // This code automatically loads suggestions if they type
      let prevEmojiSubmitAlphanumerics = emojiSubmitEl.value.replace(/[^a-zA-Z0-9]/g, "").trim();
      emojiSubmitEl.addEventListener("input", function() {
        // we only reload the suggestions if they've added new alphanumerics
        let newEmojiSubmitAlphanumerics = emojiSubmitEl.value.replace(/[^a-zA-Z0-9]/g, "").trim();
        if(prevEmojiSubmitAlphanumerics !== newEmojiSubmitAlphanumerics) {
          // show/hide suggestion box:
          if(newEmojiSubmitAlphanumerics) {
            submissionSuggestionsWrapper.style.display = "";
            // keywordSuggestionsCtn.innerHTML = `<span style=" margin: 0.25rem; padding: 0.25rem; ">Loading...</span>`;
            // emojiSuggestionsCtn.innerHTML = `<span style=" margin: 0.25rem; padding: 0.25rem; ">Loading...</span>`;
            keywordSuggestionsCtn.style.opacity = 0.6;
            emojiSuggestionsCtn.style.opacity = 0.6;
          } else {
            // submissionSuggestionsWrapper.style.display = "none";
          }
          // load emoji suggestions:
          clearTimeout(keyphraseSuggestionsDebounceTimeout);
          let opts = {updateKeywords:true, updateEmojis:true, keywordsInput:getKeywordsForSuggestionsSearch()};
          if(searchCache[JSON.stringify(opts)]) { // if it's already in cache, execute instantly
            updateSuggestions(opts);
          } else {
            keyphraseSuggestionsDebounceTimeout = setTimeout(() => { updateSuggestions(opts) }, 400);
          }
        }
        prevEmojiSubmitAlphanumerics = newEmojiSubmitAlphanumerics;
      });

      // If they're creating/pasting a multi-line combo, change to white-space:pre
      emojiSubmitEl.addEventListener("input", function() {
        if(this.value.includes("\n")) this.style.whiteSpace = "pre";
        else this.style.whiteSpace = "";
      });

      emojiSubmitEl.addEventListener("click", function() {
        submissionSuggestionsWrapper.style.display = "";
      });

      function getKeywordsForSuggestionsSearch() {
        let keywordsInput = keyphrasesSubmitEl.value;
        // if trailing/last characters in the emoji box are letters/numbers, then treat them as a keyword:
        let lastEmojiLetters = emojiSubmitEl.value.match(/([a-zA-Z0-9'\- ]+)$/);
        if(lastEmojiLetters) {
          keywordsInput += "," + lastEmojiLetters;
        }
        return keywordsInput;
      }
      
      let searchCache = {};
      async function updateSuggestions(opts={}) {

        let optionsKey = JSON.stringify(opts); // for caching

        let keywordsInput = opts.keywordsInput;

        let emojis, suggestedKeywords;
        if(searchCache[keywordsInput]) {
          ({emojis, suggestedKeywords} = searchCache[optionsKey]);
        } else {
          [
            emojis,
            suggestedKeywords,
          ] = await Promise.all([
            opts.updateEmojis ? fetch(`https://emojicombos.com/api/keywordsToEmojis?keywords=${encodeURIComponent(keywordsInput)}&key=${localStorage.loginKey || ""}`).then(r => r.json()).catch(e => (console.error(e), [])) : false,
            opts.updateKeywords ? fetch(`https://emojicombos.com/api/keywordsToRelatedKeywords?keywords=${encodeURIComponent(keywordsInput)}&key=${localStorage.loginKey || ""}`).then(r => r.json()).catch(e => (console.error(e), [])) : false,
          ]);

          searchCache[optionsKey] = {emojis, suggestedKeywords};
        }

        let endingFlexItem = `<div class="end-padding" style="flex-grow:1000000;pointer-events: none;opacity: 0;"></div>`; // to prevent even/space-between spread at end

        if(opts.updateEmojis) {
          let alreadyGotEmojis = new Set([...emojiSubmitEl.value])
          emojis = emojis.filter(e => !/^[a-zA-Z0-9\-()',\.\s]+$/.test(e));

          let emojisHtmlItems = emojis.filter(e => e.trim()).map(e => `<div>${e.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</div>`);

          emojiSuggestionsCtn.innerHTML = emojisHtmlItems.join("") + (emojisHtmlItems.length > 0 ? endingFlexItem : "");
          setTimeout(() => { // setTimeout because it may be needed for offsetHeight/Width to register properly
            emojiSuggestionsCtn.querySelectorAll("div:not(.end-padding)").forEach(el => {
              if(el.offsetWidth > 4*el.offsetHeight) {
                el.style.display = "none";
              } else {
                el.addEventListener("click", emojiSuggestionClickHandler);
              }
            });
          }, 1);
          
          // make the quick search el text grey to indicate that it's not being used for the currently-displayed suggestions:
          if(!opts.isQuickSearch) emojiQuickSearchEl.style.color = "#959595";
          
          emojiSuggestionsCtn.style.opacity = 1;
        }

        if(opts.updateKeywords) {
          let alreadyGotKeywords = new Set(keyphrasesSubmitEl.value.split(",").map(k => k.trim().toLowerCase()))
          // suggestedKeywords = suggestedKeywords.filter(k => !alreadyGotKeywords.has(k));

          let isDarkMode = window.matchMedia('(prefers-color-scheme: dark)').matches;
          let backgroundColor = isDarkMode ? "#0583b5" : "#b4eaff";

          let keywordSuggestionsHtmlItems = suggestedKeywords.map(k => `<div style="${alreadyGotKeywords.has(k) ? `background:${backgroundColor};` : ""}">${k.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</div>`);

          keywordSuggestionsCtn.innerHTML = keywordSuggestionsHtmlItems.join("") + (keywordSuggestionsHtmlItems.length > 0 ? endingFlexItem : "");
          keywordSuggestionsCtn.querySelectorAll("div").forEach(el => {
            el.addEventListener("click", keywordSuggestionClickHandler);
          });

          // make the quick search el text grey to indicate that it's not being used for the currently-displayed suggestions:
          if(!opts.isQuickSearch) keywordsQuickSearchEl.style.color = "#959595";

          keywordSuggestionsCtn.style.opacity = 1;
        }
      }
      
      keyphrasesSubmitEl.addEventListener("click", function() {
        if(keyphrasesSubmitEl.value.trim().length > 0) {
          updateSuggestions({updateKeywords:true, updateEmojis:true, keywordsInput:getKeywordsForSuggestionsSearch()});
        }
      });

      emojiQuickSearchEl.addEventListener("click", function() {
        emojiQuickSearchEl.style.color = "black";
        if(emojiQuickSearchEl.value.trim().length > 0) {
          updateSuggestions({updateEmojis:true, keywordsInput:emojiQuickSearchEl.value, isQuickSearch:true});
        }
      });
      keywordsQuickSearchEl.addEventListener("click", function() {
        keywordsQuickSearchEl.style.color = "black";
        if(keywordsQuickSearchEl.value.trim().length > 0) {
          updateSuggestions({updateKeywords:true, keywordsInput:keywordsQuickSearchEl.value, isQuickSearch:true});
        }
      });
    </script>
  </div>
  
  <script>
    window.skipKeyphraseSuggestions = false;
    async function submitEmojiComboStart() {
      let keyphrases = [...new Set(keyphrasesSubmitEl.value.split(',').map(k => k.trim()))];
      let combo = emojiSubmitEl.value;
      
      if(/^[a-zA-Z0-9\-()',.\s]+$/.test(combo)) return alert("You're submitting a new emoji combo, but you didn't input any emojis? Did you mean to use the emoji *search* 🔍 box at the top of the page instead?");
      
      if(!combo.trim() || !keyphrases.length === 0) return alert("Hmm, something is wrong 🤔 Please make sure you've added your emoji combo and some relevant comma-separated keywords and try again. Thank you!");



      try {
        if(keyphrasesSubmitEl.value.includes("#")) {
          if(!confirm("I see that your list of keywords contains the hash character ('#'). That's okay, but note that keywords and keyphrases should be separated by commas, and shouldn't start with '#' unless it is specifically relevant for that keyword/keyphrase. As an example, if your emoji combo were '🐻✨🌻♡' your keywords might be 'cute, bear, aesthetic, sunflower bear'. Please click cancel if you'd like to change your keywords, otherwise click ok to submit. Thank you!")) return;
        } if([...keyphrasesSubmitEl.value.matchAll(/ /g)].length >= 4 && !keyphrasesSubmitEl.value.includes(",")) { // <-- if they're tried to submit keywords separated by spaces:
          return alert(`You're submitting a new emoji combo, but you've only added one keyword/phrase: "${keyphrasesSubmitEl.value}". Please add 2+ keywords or phrases separated by *commas*. For example, if your emoji combo was "🐻✨🌻♡" your keywords might be "cute, bear, aesthetic, sunflower bear". Thank you!`);
        } else if(!keyphrasesSubmitEl.value.includes(",")) {
          return alert(`Please add 2+ keywords or phrases separated by commas. For example, if your emoji combo was "🐻✨🌻♡" your keywords might be "cute, bear, aesthetic, sunflower bear". Thank you!`);
        }
      } catch(e) { console.error(e); } // in case browser doesn't support matchAll
      
      document.body.appendChild(submitModalCtn); // ensure submit modal is last in <body> so it appears above anchor ads

      submitModalCtn.style.display = 'flex'; 
      submitKeyphrasesStageEl.style.display = 'none'; 
      submittedThanksEl.style.display = 'none'; 
      
      loadingRelatedKeyphrasesEl.style.display = 'flex'; 
      
      let keyphraseLowerCase = keyphrases.map(k => k.toLowerCase()); // <-- for removing suggestions that they've already added

      let relatedKeyphrases = [];
      if(!window.skipKeyphraseSuggestions) relatedKeyphrases = await fetch(`https://emojicombos.com/api/getRelatedKeyphrases?keyphrases=${keyphrases.join(",")}&key=${localStorage.loginKey || ""}`).then(r => r.json());
      relatedKeyphrases = relatedKeyphrases.filter(k => k.length < 20 && !keyphraseLowerCase.includes(k.toLowerCase()));
      
      loadingRelatedKeyphrasesEl.style.display = 'none';
      submitKeyphrasesStageEl.style.display = 'flex'; 

      if(!keyphrases.includes(window.pageTopic) && !relatedKeyphrases.includes(window.pageTopic)) relatedKeyphrases.unshift(window.pageTopic);

      let newKeyphrasesAdded = []; // the suggestions that they added
      if(relatedKeyphrases.length >= 2) {
        suggestedKeyphrasesCtn.innerHTML = "";
        for(let relatedKeyphrase of relatedKeyphrases) {
          let span = document.createElement("span");
          span.textContent = relatedKeyphrase;
          span.onclick = function() {
            if(!this.dataset.added) {
              this.dataset.added = "yes";
              newKeyphrasesAdded.push(relatedKeyphrase);
              let isDarkMode = window.matchMedia('(prefers-color-scheme: dark)').matches;
              this.style.backgroundColor = isDarkMode ? "#0061a6" : "#5fbafb";
            } else {
              this.dataset.added = "";
              newKeyphrasesAdded = newKeyphrasesAdded.filter(k => k !== relatedKeyphrase);
              this.style.backgroundColor = "";
            }
          };
          suggestedKeyphrasesCtn.appendChild(span);
        }
        await new Promise(r => window.finishedSuggestedKeyphrasesResolver=r); // the resolver is called when they click the submit button in the modal
      }

      keyphrases = [...new Set([...keyphrases, ...newKeyphrasesAdded])];

      if(newKeyphrasesAdded.length > 0) {
        keyphrasesSubmitEl.value = keyphrasesSubmitEl.value.trim() + ", " + newKeyphrasesAdded.join(", ");
      }

      submitKeyphrasesStageEl.style.display = 'none'; 
      submittedThanksEl.style.display = 'flex'; 

      submitEmojiCombo(combo, keyphrases);
      // emojiSubmitEl.value='';
      //keyphrasesSubmitEl.value='';
    }
  </script>


