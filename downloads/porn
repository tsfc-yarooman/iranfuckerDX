    function unreverseSensitiveCombo(comboCtn) {
      if(!comboCtn || comboCtn.dataset.sensitiveUnreversed === "1") return;

      comboCtn.querySelectorAll('a.keyword-link-reversed').forEach(el => {
        el.textContent = reverseSensitiveText(el.textContent);
        el.classList.remove("keyword-link-reversed");
      });

      comboCtn.querySelectorAll('.emojis.combo-text-reversed').forEach(el => {
        el.textContent = reverseSensitiveText(el.textContent);
        el.classList.remove("combo-text-reversed");
      });

      comboCtn.dataset.sensitiveUnreversed = "1";
    }
    function showSensitiveEntry(buttonEl) {
      let comboCtn = buttonEl.closest(".combo-ctn");
      let blurEl = buttonEl.closest(".sensitive-item-blur");
      if(blurEl) blurEl.style.display = "none";
      unreverseSensitiveCombo(comboCtn);
    }
    document.addEventListener("DOMContentLoaded", function() {
      if(localStorage.alwaysDisplaySensitiveEntries) {
        showAllSensitiveEntries();
      }
    });
    function showAllSensitiveEntries() {
      document.querySelector(':root').style.setProperty('--sensitive-entry-blur-display', 'none');
