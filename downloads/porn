    async function submitEmojiCombo(combo, keyphrases, opts={}) {
      if(!opts.voteMultiplier) opts.voteMultiplier = 1;
      combo = combo.replace(/^\n+|\n+$/g, ""); // remove starting and trailing newlines
      
      // if a keyphrase is one word and it's title-cased, then lower-case it, since it will be automatically displayed in title case anyway, and otherwise we'll end up with separate title-cased and non-title-cased tags for no reason:
      let normalizedKeyphrases = [];
      for(let keyphrase of keyphrases) {
        keyphrase = keyphrase.replace(/\s+/g, " ");
        if(keyphrase.toLowerCase() === keyphrase) {
          normalizedKeyphrases.push(keyphrase);
          continue;
        }
        // keyphrase has some capital letters, so we check if all words have a capital letter ONLY at the start, and in that case we can lower-case the whole keyphrase because all-lower-case keyphrases are displayed with first letter capitalised by default
        // Edit: Note that we need the `|| word.toLowerCase() === word` part for terms like "Ben 10 Monster" (the "10" can be toLowerCase-ed)
        let words = keyphrase.split(" ");
        let canBeLowerCasedCount = 0;
        for(let word of words) {
          if((word[0].toLowerCase() !== word[0] && word.slice(1).toLowerCase() === word.slice(1)) || word.toLowerCase() === word) {
            canBeLowerCasedCount++;
          }
        }
        if(canBeLowerCasedCount === words.length) {
          normalizedKeyphrases.push(keyphrase.toLowerCase());
        } else {
          normalizedKeyphrases.push(keyphrase);
        }
      }
      // keyphrases = keyphrases.map(k => k.slice(1).toLowerCase() === k.slice(1) ? k.toLowerCase() : k); // <-- just lower case it if all but the first character is lower case (no need to check if first letter is upper case)

      // let result = await fetch(`/api/submitCombo?combo=${encodeURIComponent(combo)}&keyphrases=${encodeURIComponent(normalizedKeyphrases.join(","))}&time=${Date.now()}&key=${localStorage.loginKey || ""}`).then(r => r.json()).catch(e => (console.error(e), false));
      let result = await fetch(`/api/submitCombo`, {
        method: "POST",
        body: JSON.stringify({
          combo: combo,
          keyphrases: normalizedKeyphrases.join(","),
          time: Date.now(),
          loginKey: localStorage.loginKey || "",
          voteMultiplier: opts.voteMultiplier,
        }),
      }).then(r => r.json()).catch(e => (console.error(e), false));
      if(!result || !result.success) alert("Sorry! The submission failed for an unknown reason. Please try again.");
      try { gtag('event', 'submit_combo', {}); } catch(e) { console.error(e); }
      return result;
    }

    function fallbackCopyTextToClipboard(text) {
      var textArea = document.createElement("textarea");
      textArea.value = text;

      // Avoid scrolling to bottom
      textArea.style.top = "0";
      textArea.style.left = "0";
      textArea.style.position = "fixed";

      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();

      try {
        var successful = document.execCommand('copy');
        var msg = successful ? 'successful' : 'unsuccessful';
        console.log('Copying text command was ' + msg);
      } catch (err) {
        console.error('Fallback: Oops, unable to copy', err);
      }

      document.body.removeChild(textArea);
    }
    function copyTextToClipboard(text) {
      if (!navigator.clipboard) {
        fallbackCopyTextToClipboard(text);
        return;
      }
      navigator.clipboard.writeText(text).then(function() {
        console.log('Async: Copying to clipboard was successful!');
      }, function(err) {
        console.error('Async: Could not copy text: ', err);
      });
    }
